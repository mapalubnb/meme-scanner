# ===== 飞书配置 (必填) =====
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxx
# 启动通知发送到的群聊 ID (可选，留空则不发送启动通知)
FEISHU_CHAT_ID=

# ===== AI 配置 (多提供商支持) =====
# 支持配置多个 AI 提供商，运行时通过飞书命令切换
# 格式: AI_PROVIDERS=名称1,名称2,名称3
# 每个提供商: AI_<NAME>_URL / AI_<NAME>_KEY / AI_<NAME>_MODEL (默认模型)
#
# 兼容的 OpenAI 协议 API 提供商:
# DeepSeek: https://api.deepseek.com
# OpenAI:   https://api.openai.com
# SiliconFlow: https://api.siliconflow.cn
# Groq:     https://api.groq.com/openai
# Ollama:   http://localhost:11434

# 提供商列表 (逗号分隔，第一个为默认)
AI_PROVIDERS=deepseek,openai,siliconflow

# DeepSeek
AI_DEEPSEEK_URL=https://api.deepseek.com
AI_DEEPSEEK_KEY=sk-xxxxxxxxxx
AI_DEEPSEEK_MODEL=deepseek-chat

# OpenAI
AI_OPENAI_URL=https://api.openai.com
AI_OPENAI_KEY=sk-xxxxxxxxxx
AI_OPENAI_MODEL=gpt-4o

# SiliconFlow
AI_SILICONFLOW_URL=https://api.siliconflow.cn
AI_SILICONFLOW_KEY=sk-xxxxxxxxxx
AI_SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# ===== 向后兼容 (如果未配置 AI_PROVIDERS，则使用以下单一配置) =====
AI_API_KEY=sk-xxxxxxxxxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# ===== AI 高级选项 =====
# AI 请求超时(毫秒)，默认: 非thinking模型60000，thinking模型300000
# 如果使用第三方代理（如 Cloudflare）经常 504，可适当降低
# AI_TIMEOUT=60000
# AI 源码最大长度(字符)，默认20000。越短越不容易超时，但分析精度会降低
# AI_MAX_SOURCE_LEN=20000

# ===== Etherscan V2 API (推荐) =====
# 用于合约源码/ABI查询，支持所有 EVM 链
ETHERSCAN_API_KEY=

# ===== Moralis API (可选) =====
# 用于持仓分析
MORALIS_API_KEY=
